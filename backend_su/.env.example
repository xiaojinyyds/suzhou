# Copy to ".env" for local development.
# For production deployment, prefer real environment variables (do not commit secrets).

# App
APP_NAME="苏州石像打卡API"
APP_VERSION="1.0.0"
DEBUG=True
HOST=0.0.0.0
PORT=8006

# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=daka
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=daka

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=6

# Aliyun OSS
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=replace_me
OSS_ACCESS_KEY_SECRET=replace_me
OSS_BUCKET_NAME=replace_me
OSS_BASE_URL=https://your-bucket.oss-cn-shanghai.aliyuncs.com
OSS_FOLDER_PREFIX=upload
OSS_EXPIRE_TIME=3600
OSS_CALLBACK_URL=

# Mail (QQ SMTP auth code)
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=replace_me
MAIL_FROM=you@example.com
MAIL_FROM_NAME=苏州打卡小程序

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".gif",".webp"]

# 应用配置
APP_NAME="苏州石像打卡API"
APP_VERSION="1.0.0"
DEBUG=True
HOST=0.0.0.0
PORT=8000

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=suzhou_checkin

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=suzhou-checkin
OSS_BASE_URL=https://your-bucket.oss-cn-shanghai.aliyuncs.com

# JWT 配置
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 跨域配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# 文件上传限制
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".gif",".webp"]
