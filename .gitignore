# =========================
# Root .gitignore (monorepo)
# =========================

# --- OS / Editor ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# --- Logs / temp ---
*.log
logs/
tmp/
temp/
.cache/

# --- Secrets / local env ---
.env
.env.*
!.env.example
!.env.*.example

*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.jks
*.keystore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python

venv/
.venv/
env/
ENV/
pip-wheel-metadata/

build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# --- Git ---
.git/

# --- Node / Frontend (Vite/Vue) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

dist/
dist-ssr/
coverage/
*.tsbuildinfo
.eslintcache

# Vite cache
*.timestamp-*-*.mjs
.vite/

# --- Build outputs / archives in this repo ---
*.zip
*.7z
*.rar

# --- Project specific ---
# JetBrains DB connections often include host/usernames
.idea/**/dataSources*.xml

